<div class="author">
<h1 class="article__heading">Search Results</h1>

</div>
<section class="articles">
    <% if(data.length > 0) { %>
    <ul class="article-ul">
        <% data.forEach(post => { %>
        <li>
            <a href="/post/<%= post._id %>">
                <span><%= post.title %></span>
                <span class="article-list__date">Written by <%= post.createdAt.toDateString() %></span>
            </a>
        </li>
        <% }) %>
    </ul>
      <% } else { %>
        <h2>No results found.</h2>
    <% } %>  
</section>