<div class="admin-title">
    <h2>Posts</h2>
    <a href="/admin/add-post" class="button">+ Add New</a>
</div>


    <%  if (posts && posts.length > 0) { %>
    <ul class="admin-posts">
        <% posts.forEach(post => { %>
            <li>
            <div class="post-info">
                <a href="/post/<%= post._id %>"><%= post.title %></a>
                <p>Latest Update : <%= post.updatedAt.toDateString() %></p>
            </div>

            <div class="admin-post-controls">
                <a href="/admin/edit-post/<%= post._id %>" class="btn">
                    Edit
                </a>
                <form action="/admin/delete-post/<%= post._id %>?_method=DELETE" 
                    method="POST" style="display:inline;">
                    <input type="submit" value="Delete" class="btn delete-btn">
                    </form>

            </div>
            </li>
        <% }); %>
    </ul>
    <% } else { %>
        <p>No posts found.</p>
    <% } %>

